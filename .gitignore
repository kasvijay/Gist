# Xcode
xcuserdata/
*.xcworkspace/
DerivedData/
build/
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3
*.moved-aside

# Swift Package Manager
.build/
.swiftpm/

# Track the Xcode project's Package.resolved so dependency versions are
# reproducible across checkouts (FluidAudio shipped a breaking API change in
# 0.14, so unpinned resolutions can fail on a fresh clone).
!Gist.xcodeproj/project.xcworkspace/
!Gist.xcodeproj/project.xcworkspace/xcshareddata/
!Gist.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/
!Gist.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved

# macOS
.DS_Store
*.dSYM

# Models cache (large ML models)
*.mlmodelc

# Local docs and design files (kept locally, not tracked)
docs/
DesignFiles/

# Environment
.env
